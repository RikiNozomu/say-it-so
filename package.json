{
  "name": "say-it-so",
  "private": true,
  "version": "0.13.0",
  "packageManager": "pnpm@11.1.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter core build && pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "test": "pnpm --filter web test",
    "test:coverage": "pnpm --filter web test:coverage"
  }
}
